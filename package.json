{
  "name": "quick-liquid-workspace",
  "private": true,
  "workspaces": [
    "packages/quick-liquid",
    "demo",
    "landingPage",
    "compare"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=demo",
    "dev:compare": "npm run dev --workspace=compare",
    "dev:landing": "npm run dev --workspace=landingPage",
    "dev:launch": "vite --host 127.0.0.1 --port 5177",
    "build:lib": "npm run build --workspace=packages/quick-liquid",
    "build:landing": "npm run build --workspace=landingPage",
    "build": "npm run build:lib && npm run build --workspace=demo && npm run build:landing",
    "typecheck": "npm run typecheck --workspace=packages/quick-liquid"
  }
}
